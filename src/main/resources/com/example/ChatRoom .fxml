<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<!--
    Layout  :  1280 × 720
    Top bar :  y=0,   h=56
    Panels  :  y=56,  h=664
    Left    :  x=0,   w=280
    Center  :  x=280, w=720
    Right   :  x=1000,w=280
-->
<AnchorPane prefHeight="720.0" prefWidth="1280.0"
            styleClass="anchor"
            stylesheets="@chatStyle.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.ChatRoomController"
            style="-fx-background-color: #0f0a1e;">
    <children>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  TOP NAVIGATION BAR  (full 1280px × 56px)                 -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <HBox prefHeight="56.0" prefWidth="1280.0"
              alignment="CENTER_LEFT"
              spacing="0"
              style="-fx-background-color: #1c1436;
                     -fx-border-color: rgba(123,44,255,0.25);
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 0 18 0 18;">

            <!-- ── LEFT: Profile avatar + app name ── -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  prefWidth="280" minWidth="280">

                <!-- Clickable profile avatar — opens Profile Settings popup -->
                <StackPane>
                    <Button fx:id="profileMenuBtn"
                            mnemonicParsing="false"
                            onAction="#onProfileMenuClick"
                            prefHeight="38" prefWidth="38"
                            style="-fx-background-color: transparent;
                                   -fx-border-color: transparent;
                                   -fx-padding: 0;">
                        <cursor><Cursor fx:constant="HAND"/></cursor>
                    </Button>
                    <!-- Avatar rings on top of invisible button -->
                    <StackPane mouseTransparent="true">
                        <Circle centerX="19" centerY="19" radius="19"
                                stroke="#7B2CFF" strokeWidth="2" fill="#251a45"/>
                        <ImageView fx:id="userImage" fitHeight="34" fitWidth="34">
                            <clip>
                                <Circle fx:id="userImageClip" centerX="17" centerY="17" radius="17"/>
                            </clip>
                        </ImageView>
                        <Circle centerX="30" centerY="30" radius="5"
                                fill="#22c55e" stroke="#1c1436" strokeWidth="2"
                                StackPane.alignment="BOTTOM_RIGHT"/>
                    </StackPane>
                </StackPane>

                <!-- App name -->
                <Label text="PingOwl"
                       style="-fx-text-fill: #f0eaff;
                              -fx-font-size: 18px;
                              -fx-font-family: 'DM Sans';
                              -fx-font-weight: bold;"/>
                <Label fx:id="userIdLabel"
                       style="-fx-text-fill: rgba(155,136,204,0.55);
                              -fx-font-size: 12px;
                              -fx-font-family: 'DM Sans';"
                       text=""/>
            </HBox>

            <!-- ── CENTER: Global search (Facebook-style) ── -->
            <HBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="8">
                <StackPane alignment="CENTER_LEFT" maxWidth="460" HBox.hgrow="ALWAYS">
                    <TextField fx:id="globalSearch"
                               maxWidth="460"
                               prefHeight="36"
                               promptText="🔍  Search users and friends..."
                               onKeyReleased="#onGlobalSearchTyped"
                               style="-fx-background-color: #0f0a1e;
                                      -fx-background-radius: 18;
                                      -fx-border-color: rgba(123,44,255,0.4);
                                      -fx-border-radius: 18;
                                      -fx-border-width: 1;
                                      -fx-text-fill: #f0eaff;
                                      -fx-prompt-text-fill: #6b5a8a;
                                      -fx-font-size: 13px;
                                      -fx-font-family: 'DM Sans';
                                      -fx-padding: 0 18 0 18;"/>
                </StackPane>
            </HBox>

            <!-- ── RIGHT: Friend requests + Notifications + spacer ── -->
            <HBox alignment="CENTER_RIGHT" spacing="6" prefWidth="280" minWidth="280">

                <!-- Friend Requests icon -->
                <StackPane>
                    <Button fx:id="friendRequestsBtn"
                            mnemonicParsing="false"
                            onAction="#onFriendRequestsClick"
                            prefHeight="38" prefWidth="38"
                            style="-fx-background-color: rgba(123,44,255,0.15);
                                   -fx-background-radius: 19;
                                   -fx-border-color: rgba(123,44,255,0.25);
                                   -fx-border-radius: 19;
                                   -fx-border-width: 1;
                                   -fx-text-fill: #c4b0ff;
                                   -fx-font-size: 16px;">
                        <cursor><Cursor fx:constant="HAND"/></cursor>
                    </Button>
                    <!-- Icon drawn over button -->
                    <Label text="👥" mouseTransparent="true"
                           style="-fx-font-size: 15px;" />
                    <!-- Badge -->
                    <Label fx:id="friendRequestBadge"
                           text="0"
                           visible="false"
                           StackPane.alignment="TOP_RIGHT"
                           style="-fx-background-color: #ef4444;
                                  -fx-text-fill: white;
                                  -fx-font-size: 9px;
                                  -fx-font-family: 'DM Sans';
                                  -fx-font-weight: bold;
                                  -fx-background-radius: 8;
                                  -fx-padding: 1 4 1 4;
                                  -fx-min-width: 16;
                                  -fx-alignment: center;"
                           translateX="6" translateY="-6"/>
                </StackPane>

                <!-- Notifications icon -->
                <StackPane>
                    <Button fx:id="notificationsBtn"
                            mnemonicParsing="false"
                            onAction="#onNotificationsClick"
                            prefHeight="38" prefWidth="38"
                            style="-fx-background-color: rgba(123,44,255,0.15);
                                   -fx-background-radius: 19;
                                   -fx-border-color: rgba(123,44,255,0.25);
                                   -fx-border-radius: 19;
                                   -fx-border-width: 1;
                                   -fx-text-fill: #c4b0ff;
                                   -fx-font-size: 16px;">
                        <cursor><Cursor fx:constant="HAND"/></cursor>
                    </Button>
                    <Label text="🔔" mouseTransparent="true"
                           style="-fx-font-size: 15px;" />
                    <Label fx:id="notificationBadge"
                           text="0"
                           visible="false"
                           StackPane.alignment="TOP_RIGHT"
                           style="-fx-background-color: #ef4444;
                                  -fx-text-fill: white;
                                  -fx-font-size: 9px;
                                  -fx-font-family: 'DM Sans';
                                  -fx-font-weight: bold;
                                  -fx-background-radius: 8;
                                  -fx-padding: 1 4 1 4;
                                  -fx-min-width: 16;
                                  -fx-alignment: center;"
                           translateX="6" translateY="-6"/>
                </StackPane>

            </HBox>
        </HBox>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  GLOBAL SEARCH RESULTS DROPDOWN  (hidden by default)      -->
        <!--  Appears below the search bar, full-width centered        -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <VBox fx:id="globalSearchResults"
              layoutX="410" layoutY="56"
              prefWidth="460"
              managed="false" visible="false"
              style="-fx-background-color: #1c1436;
                     -fx-background-radius: 0 0 14 14;
                     -fx-border-color: rgba(123,44,255,0.4);
                     -fx-border-radius: 0 0 14 14;
                     -fx-border-width: 0 1 1 1;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.55),14,0,0,6);">
            <!-- Results are added dynamically by the controller -->
        </VBox>


        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  LEFT SIDEBAR  (x=0, y=56, 280×664)                       -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Pane fx:id="leftbase"
              layoutY="56.0"
              prefHeight="664.0" prefWidth="280.0"
              style="-fx-background-color: #16102b;
                     -fx-border-color: rgba(123,44,255,0.18);
                     -fx-border-width: 0 1 0 0;">
            <children>

                <!-- ── Search inside sidebar ── -->
                <HBox layoutY="0" prefHeight="50" prefWidth="280"
                      alignment="CENTER"
                      style="-fx-padding: 7 12 7 12;">
                    <TextField fx:id="searchUsers"
                               HBox.hgrow="ALWAYS" maxWidth="Infinity"
                               promptText="🔍  Filter chats..."
                               style="-fx-background-color: #231a3d;
                                      -fx-background-radius: 18;
                                      -fx-border-color: rgba(123,44,255,0.3);
                                      -fx-border-radius: 18;
                                      -fx-border-width: 1;
                                      -fx-text-fill: #f0eaff;
                                      -fx-prompt-text-fill: #6b5a8a;
                                      -fx-font-size: 12px;
                                      -fx-padding: 7 14 7 14;"/>
                </HBox>

                <!-- ── Tabs ── -->
                <HBox layoutY="50" prefHeight="38" prefWidth="280"
                      spacing="0"
                      style="-fx-background-color: #1c1436;
                             -fx-padding: 4 12 4 12;">
                    <Button fx:id="usersTabBtn"
                            onAction="#onUsersTabClick"
                            mnemonicParsing="false"
                            prefHeight="30" prefWidth="122"
                            text="💬  Chats"
                            style="-fx-background-color: #7B2CFF;
                                   -fx-background-radius: 15 0 0 15;
                                   -fx-border-color: transparent;
                                   -fx-text-fill: white;
                                   -fx-font-size: 12px;
                                   -fx-font-family: 'DM Sans';">
                        <cursor><Cursor fx:constant="HAND"/></cursor>
                    </Button>
                    <Button fx:id="groupsTabBtn"
                            onAction="#onGroupsTabClick"
                            mnemonicParsing="false"
                            prefHeight="30" prefWidth="122"
                            text="👥  Groups"
                            style="-fx-background-color: #2a1f47;
                                   -fx-background-radius: 0 15 15 0;
                                   -fx-border-color: rgba(123,44,255,0.4);
                                   -fx-border-width: 1 1 1 0;
                                   -fx-border-radius: 0 15 15 0;
                                   -fx-text-fill: #9b88cc;
                                   -fx-font-size: 12px;
                                   -fx-font-family: 'DM Sans';">
                        <cursor><Cursor fx:constant="HAND"/></cursor>
                    </Button>
                </HBox>

                <!-- ── Contact list ── -->
                <ScrollPane fx:id="leftpane"
                            hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                            layoutY="88" prefHeight="576" prefWidth="280"
                            fitToWidth="true"
                            style="-fx-background-color: transparent;
                                   -fx-background: transparent;
                                   -fx-border-color: transparent;">
                    <content>
                        <VBox fx:id="friendslist" prefWidth="280"
                              style="-fx-background-color: transparent;"/>
                    </content>
                </ScrollPane>

                <!-- Hidden fx:id kept for controller compatibility -->
                <HBox fx:id="userCard" managed="false" visible="false"
                      prefHeight="0" prefWidth="0"/>

            </children>
        </Pane>


        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  CENTER CHAT AREA  (x=280, y=56, 720×664)                 -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Pane layoutX="280.0" layoutY="56.0"
              prefHeight="664.0" prefWidth="720.0"
              style="-fx-background-color: #0f0a1e;">
            <children>
                <VBox fx:id="chatbody" prefHeight="664.0" prefWidth="720.0">

                    <!-- ── Chat Header ── -->
                    <HBox fx:id="clientCard"
                          alignment="CENTER_LEFT"
                          prefHeight="62.0" prefWidth="720.0"
                          spacing="14"
                          style="-fx-background-color: #16102b;
                                 -fx-border-color: rgba(123,44,255,0.18);
                                 -fx-border-width: 0 0 1 0;
                                 -fx-padding: 0 16 0 20;">

                        <StackPane prefWidth="44" prefHeight="44">
                            <Circle centerX="22" centerY="22" radius="22" fill="#251a45"/>
                            <ImageView fx:id="clientImage" fitHeight="40" fitWidth="40">
                                <clip>
                                    <Circle fx:id="clientImageClip"
                                            centerX="20" centerY="20" radius="20"/>
                                </clip>
                            </ImageView>
                            <Circle centerX="35" centerY="35" radius="6"
                                    fill="#22c55e" stroke="#16102b" strokeWidth="2"
                                    StackPane.alignment="BOTTOM_RIGHT"/>
                        </StackPane>

                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label fx:id="clientIdLabel"
                                   text="Select a conversation"
                                   maxWidth="Infinity"
                                   style="-fx-text-fill: #f0eaff;
                                          -fx-font-size: 15px;
                                          -fx-font-family: 'DM Sans';
                                          -fx-font-weight: bold;"/>
                            <Label text="tap to view profile"
                                   style="-fx-text-fill: #6b5a8a;
                                          -fx-font-size: 11px;
                                          -fx-font-family: 'DM Sans';"/>
                        </VBox>

                        <TextField fx:id="searchMessages"
                                   prefWidth="180"
                                   promptText="Search in chat..."
                                   visible="false" managed="false"
                                   style="-fx-background-color: #231a3d;
                                          -fx-background-radius: 16;
                                          -fx-border-color: rgba(123,44,255,0.4);
                                          -fx-border-radius: 16;
                                          -fx-border-width: 1;
                                          -fx-text-fill: #f0eaff;
                                          -fx-prompt-text-fill: #6b5a8a;
                                          -fx-font-size: 12px;
                                          -fx-padding: 6 14 6 14;"/>

                        <HBox fx:id="headerButtonsBox" spacing="6" alignment="CENTER_RIGHT">
                            <Button fx:id="searchBtn"
                                    mnemonicParsing="false"
                                    onAction="#onSearchButtonClick"
                                    prefHeight="36" prefWidth="36"
                                    text="🔍"
                                    style="-fx-background-color: rgba(123,44,255,0.15);
                                           -fx-background-radius: 18;
                                           -fx-border-color: rgba(123,44,255,0.25);
                                           -fx-border-radius: 18;
                                           -fx-border-width: 1;
                                           -fx-font-size: 14px;">
                                <cursor><Cursor fx:constant="HAND"/></cursor>
                            </Button>
                            <Button fx:id="audiocall"
                                    mnemonicParsing="false"
                                    onAction="#onAudioCallClick"
                                    prefHeight="36" prefWidth="36"
                                    text="☎"
                                    style="-fx-background-color: rgba(34,197,94,0.15);
                                           -fx-background-radius: 18;
                                           -fx-border-color: rgba(34,197,94,0.3);
                                           -fx-border-radius: 18;
                                           -fx-border-width: 1;
                                           -fx-text-fill: #22c55e;
                                           -fx-font-size: 15px;">
                                <cursor><Cursor fx:constant="HAND"/></cursor>
                            </Button>
                            <Button fx:id="videocall"
                                    mnemonicParsing="false"
                                    onAction="#onVideoCallClick"
                                    prefHeight="36" prefWidth="36"
                                    text="📹"
                                    style="-fx-background-color: rgba(34,197,94,0.15);
                                           -fx-background-radius: 18;
                                           -fx-border-color: rgba(34,197,94,0.3);
                                           -fx-border-radius: 18;
                                           -fx-border-width: 1;
                                           -fx-font-size: 14px;">
                                <cursor><Cursor fx:constant="HAND"/></cursor>
                            </Button>
                            <Button fx:id="infobtn"
                                    mnemonicParsing="false"
                                    onAction="#onInfoButtonClick"
                                    prefHeight="36" prefWidth="36"
                                    text="⋯"
                                    style="-fx-background-color: rgba(123,44,255,0.15);
                                           -fx-background-radius: 18;
                                           -fx-border-color: rgba(123,44,255,0.25);
                                           -fx-border-radius: 18;
                                           -fx-border-width: 1;
                                           -fx-text-fill: #c4b0ff;
                                           -fx-font-size: 18px;
                                           -fx-font-weight: bold;">
                                <cursor><Cursor fx:constant="HAND"/></cursor>
                            </Button>
                        </HBox>
                    </HBox>

                    <!-- ── Message Area ── -->
                    <Pane VBox.vgrow="ALWAYS" prefWidth="720.0">

                        <ImageView fx:id="chatBG"
                                   fitHeight="602.0" fitWidth="720.0"
                                   pickOnBounds="true" preserveRatio="false"
                                   opacity="0.07">
                            <image>
                                <Image url="@../Images/hogwarts_background.jpg"/>
                            </image>
                        </ImageView>

                        <ScrollPane fx:id="chatScroll"
                                    fitToWidth="true"
                                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    prefHeight="602.0" prefWidth="720.0"
                                    style="-fx-background-color: transparent;
                                           -fx-background: transparent;
                                           -fx-border-color: transparent;">
                            <content>
                                <VBox fx:id="msgbox" prefWidth="720.0" spacing="4">
                                    <padding>
                                        <Insets bottom="16" top="16" left="16" right="16"/>
                                    </padding>
                                </VBox>
                            </content>
                        </ScrollPane>

                        <VBox fx:id="groupProfilePane"
                              managed="false" visible="false"
                              prefHeight="602.0" prefWidth="720.0"
                              spacing="0" styleClass="group-profile-pane"/>

                        <StackPane fx:id="chatStateOverlay"
                                   prefHeight="602.0" prefWidth="720.0"
                                   pickOnBounds="false" mouseTransparent="true">
                            <children>
                                <VBox fx:id="chatLoadingPane"
                                      alignment="CENTER" spacing="14"
                                      managed="false" visible="false"
                                      maxHeight="Infinity" maxWidth="Infinity"
                                      style="-fx-background-color: rgba(15,10,30,0.85);">
                                    <ProgressIndicator fx:id="chatLoadingIndicator"
                                                       prefWidth="42" prefHeight="42"/>
                                    <Label fx:id="chatLoadingLabel"
                                           text="Loading messages..."
                                           style="-fx-text-fill: #9b88cc;
                                                  -fx-font-size: 13px;
                                                  -fx-font-family: 'DM Sans';"/>
                                </VBox>
                                <VBox fx:id="chatErrorPane"
                                      alignment="TOP_CENTER"
                                      managed="false" visible="false"
                                      pickOnBounds="false"
                                      StackPane.alignment="TOP_CENTER">
                                    <padding><Insets top="14" left="14" right="14"/></padding>
                                    <Label fx:id="chatErrorLabel"
                                           wrapText="true" maxWidth="580"
                                           style="-fx-text-fill: #fca5a5;
                                                  -fx-background-color: rgba(220,38,38,0.2);
                                                  -fx-background-radius: 10;
                                                  -fx-border-color: rgba(220,38,38,0.4);
                                                  -fx-border-radius: 10;
                                                  -fx-border-width: 1;
                                                  -fx-padding: 10 16;
                                                  -fx-font-size: 12px;
                                                  -fx-font-family: 'DM Sans';"/>
                                </VBox>
                            </children>
                        </StackPane>

                        <StackPane fx:id="callOverlay"
                                   prefHeight="602.0" prefWidth="720.0"
                                   visible="false"
                                   style="-fx-background-color: rgba(0,0,0,0.82);"/>
                    </Pane>

                    <!-- ── Input Bar ── -->
                    <HBox prefHeight="62.0" prefWidth="720.0"
                          spacing="10" alignment="CENTER"
                          style="-fx-background-color: #16102b;
                                 -fx-border-color: rgba(123,44,255,0.18);
                                 -fx-border-width: 1 0 0 0;
                                 -fx-padding: 11 16 11 16;">

                        <Button fx:id="sendImg"
                                mnemonicParsing="false"
                                onAction="#onSendImageClick"
                                prefHeight="38" prefWidth="38"
                                text="🖼"
                                style="-fx-background-color: rgba(123,44,255,0.15);
                                       -fx-background-radius: 19;
                                       -fx-border-color: rgba(123,44,255,0.25);
                                       -fx-border-radius: 19;
                                       -fx-border-width: 1;
                                       -fx-font-size: 14px;">
                            <cursor><Cursor fx:constant="HAND"/></cursor>
                        </Button>
                        <Button fx:id="sendFile"
                                mnemonicParsing="false"
                                onAction="#onSendFileClick"
                                prefHeight="38" prefWidth="38"
                                text="📎"
                                style="-fx-background-color: rgba(123,44,255,0.15);
                                       -fx-background-radius: 19;
                                       -fx-border-color: rgba(123,44,255,0.25);
                                       -fx-border-radius: 19;
                                       -fx-border-width: 1;
                                       -fx-font-size: 14px;">
                            <cursor><Cursor fx:constant="HAND"/></cursor>
                        </Button>

                        <TextField fx:id="msgField"
                                   HBox.hgrow="ALWAYS"
                                   prefHeight="40"
                                   promptText="Write a message..."
                                   style="-fx-background-color: #231a3d;
                                          -fx-background-radius: 20;
                                          -fx-border-color: rgba(123,44,255,0.35);
                                          -fx-border-radius: 20;
                                          -fx-border-width: 1;
                                          -fx-text-fill: #f0eaff;
                                          -fx-prompt-text-fill: #6b5a8a;
                                          -fx-font-size: 14px;
                                          -fx-font-family: 'DM Sans';
                                          -fx-padding: 0 18 0 18;"/>

                        <Button fx:id="voiceToText"
                                mnemonicParsing="false"
                                onAction="#onVoiceToTextClick"
                                prefHeight="38" prefWidth="38"
                                text="🎤"
                                style="-fx-background-color: rgba(123,44,255,0.15);
                                       -fx-background-radius: 19;
                                       -fx-border-color: rgba(123,44,255,0.25);
                                       -fx-border-radius: 19;
                                       -fx-border-width: 1;
                                       -fx-font-size: 14px;">
                            <cursor><Cursor fx:constant="HAND"/></cursor>
                        </Button>
                        <Button fx:id="sendEmoji"
                                mnemonicParsing="false"
                                onAction="#onEmojiButtonClick"
                                prefHeight="38" prefWidth="38"
                                text="😊"
                                style="-fx-background-color: rgba(123,44,255,0.15);
                                       -fx-background-radius: 19;
                                       -fx-border-color: rgba(123,44,255,0.25);
                                       -fx-border-radius: 19;
                                       -fx-border-width: 1;
                                       -fx-font-size: 14px;">
                            <cursor><Cursor fx:constant="HAND"/></cursor>
                        </Button>
                        <Button fx:id="sendMsg"
                                mnemonicParsing="false"
                                onAction="#onSendMessageClick"
                                prefHeight="40" prefWidth="40"
                                text="➤"
                                style="-fx-background-color: linear-gradient(to bottom right, #9b30ff, #6d12e8);
                                       -fx-background-radius: 20;
                                       -fx-border-color: transparent;
                                       -fx-text-fill: white;
                                       -fx-font-size: 16px;
                                       -fx-effect: dropshadow(gaussian,rgba(123,44,255,0.55),10,0,0,2);">
                            <cursor><Cursor fx:constant="HAND"/></cursor>
                        </Button>
                    </HBox>

                </VBox>
            </children>
        </Pane>


        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  RIGHT PANEL  (x=1000, y=56, 280×664)                     -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <StackPane layoutX="1000.0" layoutY="56.0"
                   prefHeight="664.0" prefWidth="280.0">
            <children>

                <ImageView fitHeight="664.0" fitWidth="280.0"
                           pickOnBounds="true" preserveRatio="false"
                           opacity="0.12">
                    <image>
                        <Image url="@../Images/LoginForm/sidebar.gif"/>
                    </image>
                </ImageView>

                <Pane prefHeight="664.0" prefWidth="280.0"
                      style="-fx-background-color: rgba(22,16,43,0.97);
                             -fx-border-color: rgba(123,44,255,0.18);
                             -fx-border-width: 0 0 0 1;"/>

                <!-- ── AI Panel ── -->
