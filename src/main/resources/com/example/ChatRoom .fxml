<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0"
            styleClass="anchor"
            stylesheets="@chatStyle.css"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.ChatRoomController">
    <children>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- LEFT PANEL                                               -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Pane fx:id="leftbase" prefHeight="720.0" prefWidth="319.0"
              style="-fx-background-color: #2e1a47;">
            <children>

                <!-- User Header -->
                <HBox fx:id="userCard" alignment="CENTER_LEFT"
                      prefHeight="70.0" prefWidth="319.0"
                      spacing="15" styleClass="header-user">
                    <padding><Insets left="15.0" /></padding>
                    <ImageView fx:id="userImage" fitHeight="50" fitWidth="50">
                        <clip>
                            <Circle fx:id="userImageClip" centerX="25" centerY="25" radius="25" />
                        </clip>
                    </ImageView>
                    <Label fx:id="userIdLabel" text="User" textFill="#f3f4d2">
                        <font><Font name="DM Sans" size="16.0" /></font>
                    </Label>
                </HBox>

                <!-- Search Field -->
                <TextField fx:id="searchUsers"
                           layoutY="70.0" prefHeight="40.0" prefWidth="319.0"
                           promptText="Search..." styleClass="text-fields">
                    <padding><Insets left="15.0" right="15.0" /></padding>
                </TextField>

                <!-- Tab Buttons -->
                <HBox layoutY="110.0" prefHeight="40.0" prefWidth="319.0"
                      style="-fx-background-color: #251340;">
                    <Button fx:id="usersTabBtn"
                            onAction="#onUsersTabClick"
                            mnemonicParsing="false"
                            prefHeight="40.0" prefWidth="159.5"
                            text="Users">
                        <font><Font name="DM Sans" size="13.0" /></font>
                        <cursor><Cursor fx:constant="HAND" /></cursor>
                    </Button>
                    <Button fx:id="groupsTabBtn"
                            onAction="#onGroupsTabClick"
                            mnemonicParsing="false"
                            prefHeight="40.0" prefWidth="159.5"
                            text="Groups">
                        <font><Font name="DM Sans" size="13.0" /></font>
                        <cursor><Cursor fx:constant="HAND" /></cursor>
                    </Button>
                </HBox>

                <!-- Users / Groups List -->
                <ScrollPane fx:id="leftpane"
                            hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                            layoutY="150.0" prefHeight="570.0" prefWidth="319.0"
                            styleClass="left-scroll">
                    <content>
                        <VBox fx:id="friendslist" styleClass="friends-list" />
                    </content>
                </ScrollPane>

            </children>
        </Pane>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- RIGHT SIDEBAR                                            -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <StackPane layoutX="926.0" prefHeight="720.0" prefWidth="354.0">
            <children>

                <!-- Background GIF -->
                <ImageView fitHeight="720.0" fitWidth="354.0"
                           pickOnBounds="true" preserveRatio="false">
                    <image>
                        <Image url="@../Images/LoginForm/sidebar.gif" />
                    </image>
                </ImageView>

                <!-- AI Panel -->
                <Pane fx:id="geminiPane" prefHeight="720.0" prefWidth="354.0"
                      visible="false"
                      style="-fx-background-color: rgba(18,40,56,0.95);">
                    <children>
                        <Label layoutX="20.0" layoutY="15.0"
                               text="AI Assistant" textFill="#f3f4d2">
                            <font><Font name="DM Sans" size="24.0" /></font>
                        </Label>

                        <ScrollPane fx:id="geminiscrollpane"
                                    fitToWidth="true"
                                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    layoutY="60.0" prefHeight="600.0" prefWidth="354.0">
                            <content>
                                <VBox fx:id="geminibox" prefWidth="354.0" spacing="8" />
                            </content>
                        </ScrollPane>

                        <HBox layoutX="10.0" layoutY="670.0"
                              prefHeight="40.0" prefWidth="334.0" spacing="8">
                            <children>
                                <TextField fx:id="geminimsg"
                                           prefHeight="40.0" prefWidth="280.0"
                                           promptText="Ask AI..."
                                           styleClass="text-fields" />
                                <!-- Fixed: calls onGeminiSendClick, NOT onSendMessageClick -->
                                <Button fx:id="geminisend"
                                        mnemonicParsing="false"
                                        onAction="#onGeminiSendClick"
                                        prefHeight="40.0" prefWidth="40.0"
                                        styleClass="sending-btn" text="→">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </Pane>

                <!-- Info Panel -->
                <Pane fx:id="infoPane" prefHeight="720.0" prefWidth="354.0"
                      style="-fx-background-color: rgba(18,40,56,0.95);">
                    <children>

                        <Button fx:id="createGroupBtn"
                                layoutX="27.0" layoutY="20.0"
                                mnemonicParsing="false"
                                onAction="#createGroup"
                                prefHeight="40.0" prefWidth="300.0"
                                styleClass="create-group-btn"
                                text="＋  Create Chat Group">
                            <font><Font name="DM Sans" size="14.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>

                        <ImageView fx:id="userImage1"
                                   fitHeight="80.0" fitWidth="80.0"
                                   layoutX="137.0" layoutY="80.0">
                            <clip>
                                <Circle fx:id="userImageClip1"
                                        centerX="40" centerY="40" radius="40" />
                            </clip>
                        </ImageView>

                        <Button fx:id="changeDOBtn"
                                layoutX="200.0" layoutY="140.0"
                                mnemonicParsing="false"
                                onAction="#onChangeDisplayPictureClick"
                                prefHeight="30.0" prefWidth="30.0"
                                style="-fx-background-color: #a0b9a5;
                                       -fx-background-radius: 15;
                                       -fx-border-width: 0;"
                                text="📷">
                            <font><Font size="14.0" /></font>
                        </Button>

                        <Label layoutX="27.0" layoutY="200.0"
                               text="Username" textFill="#f3f4d2">
                            <font><Font name="DM Sans" size="14.0" /></font>
                        </Label>
                        <Label fx:id="USERNAME"
                               layoutX="27.0" layoutY="225.0"
                               prefHeight="25.0" prefWidth="300.0"
                               textFill="#a0b9a5">
                            <font><Font name="DM Sans" size="16.0" /></font>
                        </Label>

                        <Label layoutX="27.0" layoutY="270.0"
                               text="Status" textFill="#f3f4d2">
                            <font><Font name="DM Sans" size="14.0" /></font>
                        </Label>

                        <Button fx:id="geminiBTN"
                                layoutX="27.0" layoutY="660.0"
                                mnemonicParsing="false"
                                onAction="#onGeminiButtonClick"
                                styleClass="sending-btn"
                                text="✦ AI"
                                prefWidth="70" prefHeight="40">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                            <font><Font name="DM Sans" size="14.0" /></font>
                        </Button>

                    </children>
                </Pane>

            </children>
        </StackPane>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- MAIN CHAT AREA                                           -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Pane layoutX="319.0" prefHeight="720.0" prefWidth="607.0"
              style="-fx-background-color: #2e1a47;">
            <children>
                <!-- VBox splits: chat area grows, input bar stays at bottom -->
                <VBox fx:id="chatbody" prefHeight="720.0" prefWidth="607.0">
                    <children>

                        <!-- Chat area (grows to fill space) -->
                        <Pane VBox.vgrow="ALWAYS" prefWidth="607.0">
                            <children>

                                <!-- Background image -->
                                <ImageView fx:id="chatBG"
                                           fitHeight="650.0" fitWidth="607.0"
                                           layoutY="70.0"
                                           pickOnBounds="true"
                                           preserveRatio="false"
                                           opacity="0.35">
                                    <image>
                                        <Image url="@../Images/hogwarts_background.jpg" />
                                    </image>
                                </ImageView>

                                <!-- Messages scroll -->
                                <ScrollPane fx:id="chatScroll"
                                            styleClass="chat-scroll"
                                            fitToWidth="true"
                                            hbarPolicy="NEVER"
                                            vbarPolicy="AS_NEEDED"
                                            layoutY="70.0"
                                            prefHeight="650.0"
                                            prefWidth="607.0">
                                    <content>
                                        <VBox fx:id="msgbox"
                                              prefWidth="607.0"
                                              spacing="8">
                                            <padding>
                                                <Insets bottom="12" top="8" />
                                            </padding>
                                        </VBox>
                                    </content>
                                </ScrollPane>

                                <!-- Group profile (covers message area; opened from group name / header) -->
                                <VBox fx:id="groupProfilePane"
                                      layoutY="70.0"
                                      managed="false"
                                      prefHeight="650.0"
                                      prefWidth="607.0"
                                      spacing="0.0"
                                      visible="false"
                                      styleClass="group-profile-pane" />

                                <!-- Loading / error overlay (chat messages area) -->
                                <StackPane fx:id="chatStateOverlay"
                                           layoutY="70.0"
                                           prefHeight="650.0" prefWidth="607.0"
                                           pickOnBounds="false"
                                           mouseTransparent="true">
                                    <children>
                                        <VBox fx:id="chatLoadingPane"
                                              alignment="CENTER"
                                              spacing="12.0"
                                              managed="false"
                                              visible="false"
                                              style="-fx-background-color: rgba(46,26,71,0.92);"
                                              maxHeight="Infinity"
                                              maxWidth="Infinity">
                                            <ProgressIndicator fx:id="chatLoadingIndicator" prefWidth="40.0" prefHeight="40.0" />
                                            <Label fx:id="chatLoadingLabel"
                                                   text="Loading messages..."
                                                   textFill="#a0b9a5">
                                                <font><Font name="DM Sans" size="13.0" /></font>
                                            </Label>
                                        </VBox>
                                        <VBox fx:id="chatErrorPane"
                                              alignment="TOP_CENTER"
                                              managed="false"
                                              visible="false"
                                              pickOnBounds="false"
                                              StackPane.alignment="TOP_CENTER">
                                            <padding><Insets top="12.0" left="12.0" right="12.0" /></padding>
                                            <Label fx:id="chatErrorLabel"
                                                   wrapText="true"
                                                   maxWidth="560.0"
                                                   textFill="#ffaaaa"
                                                   style="-fx-background-color: rgba(180,40,40,0.35); -fx-background-radius: 8; -fx-padding: 10 14;">
                                                <font><Font name="DM Sans" size="12.0" /></font>
                                            </Label>
                                        </VBox>
                                    </children>
                                </StackPane>

                                <!-- Call overlay (hidden) -->
                                <StackPane fx:id="callOverlay"
                                           layoutY="70.0"
                                           prefHeight="650.0" prefWidth="607.0"
                                           style="-fx-background-color: rgba(0,0,0,0.8);"
                                           visible="false" />

                                <!-- Chat header -->
                                <HBox fx:id="clientCard"
                                      alignment="CENTER_LEFT"
                                      prefHeight="70.0" prefWidth="607.0"
                                      spacing="15.0"
                                      styleClass="header-user">
                                    <padding>
                                        <Insets left="15.0" right="15.0" />
                                    </padding>
                                    <children>
                                        <ImageView fx:id="clientImage"
                                                   fitHeight="50.0" fitWidth="50.0">
                                            <clip>
                                                <Circle fx:id="clientImageClip"
                                                        centerX="25" centerY="25"
                                                        radius="25" />
                                            </clip>
                                        </ImageView>
                                        <Label fx:id="clientIdLabel"
                                               prefWidth="250.0"
                                               text="Select a chat"
                                               textFill="#f3f4d2">
                                            <font><Font name="DM Sans" size="16.0" /></font>
                                        </Label>

                                        <Pane HBox.hgrow="ALWAYS" />

                                        <HBox fx:id="headerButtonsBox"
                                              spacing="10" alignment="CENTER_RIGHT">
                                            <Button fx:id="audiocall"
                                                    mnemonicParsing="false"
                                                    onAction="#onAudioCallClick"
                                                    styleClass="call-btn"
                                                    prefHeight="40.0" prefWidth="40.0"
                                                    text="📞">
                                                <font><Font size="16.0" /></font>
                                            </Button>
                                            <Button fx:id="videocall"
                                                    mnemonicParsing="false"
                                                    onAction="#onVideoCallClick"
                                                    styleClass="call-btn"
                                                    prefHeight="40.0" prefWidth="40.0"
                                                    text="📹">
                                                <font><Font size="16.0" /></font>
                                            </Button>
                                            <Button fx:id="infobtn"
                                                    mnemonicParsing="false"
                                                    onAction="#onInfoButtonClick"
                                                    styleClass="info-btn"
                                                    prefHeight="40.0" prefWidth="40.0"
                                                    text="ℹ">
                                                <font><Font size="16.0" /></font>
                                            </Button>
                                        </HBox>
                                    </children>
                                </HBox>

                            </children>
                        </Pane>

                        <!-- Message Input Bar (pinned to bottom) -->
                        <HBox prefHeight="70.0" prefWidth="607.0"
                              spacing="8.0"
                              style="-fx-background-color: #2b1d44; -fx-padding: 15;">
                            <children>
                                <Button fx:id="sendImg"
                                        mnemonicParsing="false"
                                        onAction="#onSendImageClick"
                                        prefHeight="40.0" prefWidth="40.0"
                                        styleClass="sending-btn" text="+">
                                    <font><Font name="DM Sans" size="20.0" /></font>
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>

                                <TextField fx:id="msgField"
                                           prefHeight="40.0"
                                           HBox.hgrow="ALWAYS"
                                           onAction="#onSendMessageClick"
                                           promptText="Type a message..."
                                           styleClass="text-fields" />

                                <Button fx:id="voiceToText"
                                        mnemonicParsing="false"
                                        onAction="#onVoiceToTextClick"
                                        prefHeight="40.0" prefWidth="40.0"
                                        styleClass="info-btn" text="🎤">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                    <font><Font size="16.0" /></font>
                                </Button>

                                <Button fx:id="sendEmoji"
                                        mnemonicParsing="false"
                                        onAction="#onEmojiButtonClick"
                                        prefHeight="40.0" prefWidth="40.0"
                                        styleClass="sending-btn" text="😊">
                                    <font><Font size="16.0" /></font>
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                </Button>

                                <Button fx:id="sendMsg"
                                        mnemonicParsing="false"
                                        onAction="#onSendMessageClick"
                                        prefHeight="40.0" prefWidth="40.0"
                                        styleClass="send-msg" text="➤">
                                    <cursor><Cursor fx:constant="HAND" /></cursor>
                                    <font><Font name="DM Sans" size="18.0" /></font>
                                </Button>
                            </children>
                        </HBox>

                    </children>
                </VBox>
            </children>
        </Pane>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- EMOJI PICKER OVERLAY                                     -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- Clicking the backdrop closes the picker -->
        <Pane fx:id="emojipane_test"
              prefHeight="720.0" prefWidth="1280.0"
              visible="false"
              onMouseClicked="#onCloseEmojiPicker"
              style="-fx-background-color: rgba(0,0,0,0.35);">
            <children>
                <!-- consumeEvent prevents backdrop close when clicking inside picker -->
                <ScrollPane fx:id="emojiscroller"
                            hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                            layoutX="530.0" layoutY="380.0"
                            prefHeight="280.0" prefWidth="260.0"
                            onMouseClicked="#consumeEvent"
                            style="-fx-background-color: #f3f4d2;
                                   -fx-background-radius: 12;
                                   -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.4),12,0,0,4);">
                    <content>
                        <VBox fx:id="emojibox"
                              prefWidth="260.0"
                              style="-fx-background-color: #f3f4d2;"
                              spacing="4">
                            <padding><Insets bottom="8" left="8" right="8" top="8" /></padding>
                        </VBox>
                    </content>
                </ScrollPane>

                <Button fx:id="closeEmojiPicker"
                        layoutX="774.0" layoutY="354.0"
                        mnemonicParsing="false"
                        onAction="#onCloseEmojiPicker"
                        prefHeight="26.0" prefWidth="26.0"
                        style="-fx-background-color: #5e8581;
                               -fx-text-fill: #f3f4d2;
                               -fx-background-radius: 13;"
                        text="×">
                    <font><Font name="DM Sans" size="14.0" /></font>
                </Button>
            </children>
        </Pane>

    </children>
</AnchorPane>
