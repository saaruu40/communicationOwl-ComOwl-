<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>

<fx:root prefHeight="800.0" prefWidth="1200.0" stylesheets="@StyleSignUp.css" type="AnchorPane"
         xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
         fx:controller="com.example.SignUpController">


    <!-- Background Image -->
    <ImageView fitHeight="800.0" fitWidth="1200.0" preserveRatio="false"
               AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
               AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <image>
            <Image url="@Image/SignIn-SignUp.png" />
        </image>
    </ImageView>

    <StackPane layoutX="390.0" layoutY="50.0" prefHeight="680.0" prefWidth="420.0">
        <Rectangle arcHeight="20.0" arcWidth="20.0" fill="#0d0528AA" height="680.0"
                   stroke="#7B2CFF" strokeWidth="1.5" width="420.0" />

        <VBox maxWidth="355.0" prefWidth="355.0" spacing="12.0">
            <padding>
                <Insets bottom="30.0" left="28.0" right="28.0" top="30.0" />
            </padding>

            <Rectangle fill="#8E63FF" height="1.0" width="350.0" />



            <!-- Profile Picture -->
            <HBox alignment="CENTER">
                <ImageView fx:id="profileImageView"
                           fitHeight="100.0" fitWidth="100.0"
                           onMouseClicked="#chooseProfilePicture"
                           style="-fx-cursor: hand;"
                           preserveRatio="false" />
            </HBox>
           <!-- <ImageView fx:id="profileImageView"
                       fitHeight="100.0" fitWidth="100.0"
                       onMouseClicked="#chooseProfilePicture"
                       style="-fx-cursor: hand;"
                       preserveRatio="false" /> -->
            <!--<Label style="-fx-text-fill: #bcaeff; -fx-font-size: 11px; -fx-font-family: 'Times New Roman'; -fx-cursor: hand;"
                   onMouseClicked="#chooseProfilePicture"
                   text="Click to add profile picture (optional)" />-->

           <!-- <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-family: 'Times New Roman';" text="SIGN UP" />-->

            <Label style="-fx-text-fill: #d7cfff; -fx-font-size: 12px; -fx-font-family: 'Times New Roman';" text="FIRST NAME" />
            <TextField fx:id="firstNameField" prefHeight="34.0"
                       style="-fx-background-color: transparent; -fx-border-color: #7B2CFF; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: white; -fx-prompt-text-fill: #bcaeff;" />

            <Label style="-fx-text-fill: #d7cfff; -fx-font-size: 12px; -fx-font-family: 'Times New Roman';" text="LAST NAME" />
            <TextField fx:id="lastNameField" prefHeight="34.0"
                       style="-fx-background-color: transparent; -fx-border-color: #7B2CFF; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: white; -fx-prompt-text-fill: #bcaeff;" />

            <Label style="-fx-text-fill: #d7cfff; -fx-font-size: 12px; -fx-font-family: 'Times New Roman';" text="EMAIL ADDRESS" />
            <TextField fx:id="emailField" prefHeight="34.0"
                       style="-fx-background-color: transparent; -fx-border-color: #7B2CFF; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: white; -fx-prompt-text-fill: #bcaeff;" />

            <Label style="-fx-text-fill: #d7cfff; -fx-font-size: 12px; -fx-font-family: 'Times New Roman';" text="PASSWORD" />
            <PasswordField fx:id="passwordField" prefHeight="34.0"
                           style="-fx-background-color: transparent; -fx-border-color: #7B2CFF; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: white; -fx-prompt-text-fill: #bcaeff;" />

            <Label style="-fx-text-fill: #d7cfff; -fx-font-size: 12px; -fx-font-family: 'Times New Roman';" text="CONFIRM PASSWORD" />
            <PasswordField fx:id="confirmPasswordField" prefHeight="34.0"
                           style="-fx-background-color: transparent; -fx-border-color: #7B2CFF; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: white; -fx-prompt-text-fill: #bcaeff;" />

            <Label style="-fx-text-fill: #d7cfff; -fx-font-size: 12px; -fx-font-family: 'Times New Roman';" text="RECOVERY QUESTION" />
            <TextField fx:id="recoveryQuestionField" prefHeight="34.0"
                       style="-fx-background-color: transparent; -fx-border-color: #7B2CFF; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: white; -fx-prompt-text-fill: #bcaeff;" />

            <Label style="-fx-text-fill: #d7cfff; -fx-font-size: 12px; -fx-font-family: 'Times New Roman';" text="RECOVERY ANSWER" />
            <TextField fx:id="recoveryAnswerField" prefHeight="34.0"
                       style="-fx-background-color: transparent; -fx-border-color: #7B2CFF; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: white; -fx-prompt-text-fill: #bcaeff;" />

            <HBox alignment="CENTER">
                <Button fx:id="signUpButton" prefWidth="200.0" prefHeight="30.0"
                        onMouseClicked="#SignUpHandle"
                        style="-fx-background-color: linear-gradient(to bottom, #7B2CFF, #5D16CC); -fx-text-fill: white; -fx-font-size: 18px; -fx-font-family: 'Times New Roman'; -fx-border-color: #cdb7ff; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;"
                        text="Sign Up" />
            </HBox>

            <Label fx:id="errorMessage" text="" textFill="red" visible="false"
                   style="-fx-font-size: 13px; -fx-font-family: 'Times New Roman';" >

            <VBox.margin>
                <Insets top="-10.0" />
            </VBox.margin>
        </Label>

            <Label onMouseClicked="#goToSignIn"
                   style="-fx-text-fill: #bcaeff; -fx-cursor: hand; -fx-font-family: 'Times New Roman'; -fx-font-size: 13px; -fx-underline: true;"
                   text="Already have an account? Sign In">

            </Label>

        </VBox>
    </StackPane>

</fx:root>