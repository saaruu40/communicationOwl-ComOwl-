<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.UpdateAccountController"
            prefWidth="280.0"
            style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 15, 0, 0, 4);">

    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- Back -->
        <HBox alignment="CENTER_LEFT">
            <padding><Insets top="8" left="10" bottom="5" /></padding>
            <Label text="←" onMouseClicked="#goBack"
                   style="-fx-text-fill: #555; -fx-cursor: hand; -fx-font-size: 16px;" />
        </HBox>

        <!-- Title -->
        <Label text="Update Account"
               maxWidth="1.7976931348623157E308"
               alignment="CENTER"
               style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;">
            <VBox.margin><Insets bottom="15" left="20" /></VBox.margin>
        </Label>

        <Separator />

        <!-- Options -->
        <VBox spacing="0.0">
            <padding><Insets top="5" bottom="15" /></padding>

            <Label text="Change name" maxWidth="1.7976931348623157E308"
                   onMouseClicked="#changeName"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a; -fx-cursor: hand; -fx-padding: 12 0 12 20;" />

            <Label text="Change profile picture" maxWidth="1.7976931348623157E308"
                   onMouseClicked="#changeProfilePicture"
                   style="-fx-font-size: 14px; -fx-text-fill: #1a1a1a; -fx-cursor: hand; -fx-padding: 12 0 12 20;" />

            <Label text="Change password" maxWidth="1.7976931348623157E308"
                   onMouseClicked="#changePassword"
                   style="-fx-font-size: 14px; -fx-text-fill: #1a1a1a; -fx-cursor: hand; -fx-padding: 12 0 12 20;" />
        </VBox>

    </VBox>
</AnchorPane>