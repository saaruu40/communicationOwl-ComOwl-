<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.layout.HBox?>

<fx:root prefHeight="800.0" prefWidth="1200.0" stylesheets="@StyleForgotPassword.css" type="AnchorPane"
         xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
         fx:controller="com.example.ForgotPasswordController">

    <ImageView fitHeight="800.0" fitWidth="1200.0" preserveRatio="false"
               AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
               AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <image>
            <Image url="@Image/forgetPass-resetPass.png" />
        </image>
    </ImageView>

    <StackPane layoutX="390.0" layoutY="85.0" prefHeight="500.0" prefWidth="420.0">
        <Rectangle arcHeight="20.0" arcWidth="20.0" fill="#0d0528AA"
                   height="500.0" stroke="#7B2CFF" strokeWidth="1.5" width="420.0" />

        <VBox maxWidth="355.0" prefWidth="355.0" spacing="14.0">
            <padding>
                <Insets bottom="30.0" left="28.0" right="28.0" top="35.0" />
            </padding>

            <Rectangle fill="#8E63FF" height="1.0" width="350.0" />

            <!-- Email -->
            <Label style="-fx-text-fill: #d7cfff; -fx-font-size: 16px; -fx-font-family: 'Times New Roman';" text="EMAIL ADDRESS" />
            <TextField fx:id="emailField" prefHeight="34.0"
                       onKeyReleased="#onEmailTyped"
                       style="-fx-background-color: transparent; -fx-border-color: #7B2CFF; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: white; -fx-prompt-text-fill: #bcaeff;" />

            <!-- Recovery Question — অটো দেখাবে -->
            <Label fx:id="recoveryQuestionLabel"
                   style="-fx-text-fill: #bcaeff; -fx-font-size: 14px; -fx-font-family: 'Times New Roman'; -fx-wrap-text: true;"
                   visible="false" />

            <!-- Answer -->
            <Label style="-fx-text-fill: #d7cfff; -fx-font-size: 16px; -fx-font-family: 'Times New Roman';" text="ANSWER" />
            <TextField fx:id="answerField" prefHeight="34.0" visible="false"
                       style="-fx-background-color: transparent; -fx-border-color: #7B2CFF; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: white; -fx-prompt-text-fill: #bcaeff;" />

            <!-- Error Message -->
            <Label fx:id="errorMessage" text="" textFill="red" visible="false"
                   style="-fx-font-size: 13px; -fx-font-family: 'Times New Roman';" />

            <!-- Recover Button -->
            <HBox fx:id="recoverButtonBox" alignment="CENTER" visible="false" managed="false">
                <Button fx:id="recoverButton" onMouseClicked="#recoverPasswordHandle"
                        prefWidth="200.0" prefHeight="46.0"
                        style="-fx-background-color: linear-gradient(to bottom, #7B2CFF, #5D16CC); -fx-text-fill: white; -fx-font-size: 22px; -fx-font-family: 'Times New Roman'; -fx-border-color: #cdb7ff; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;"
                        text="Recover Password" />
            </HBox>

            <!-- Back to Sign In -->
            <Label style="-fx-text-fill: #bcaeff; -fx-font-size: 14px; -fx-cursor: hand;"
                   text="Remembered it? Back to Sign In"
                   onMouseClicked="#backToSignIn" />

        </VBox>
    </StackPane>

</fx:root>