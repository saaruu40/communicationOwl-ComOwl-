<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<!--
    Layout  :  1280 × 720
    Top bar :  y=0,   h=56
    Panels  :  y=56,  h=664
    Left    :  x=0,   w=280
    Center  :  x=280, w=720
    Right   :  x=1000,w=280
-->

<AnchorPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #0f0a1e;" styleClass="anchor" stylesheets="@chatStyle.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.ChatRoomController">
    <children>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  TOP NAVIGATION BAR  (full 1280px × 56px)                 -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <HBox alignment="CENTER_LEFT" prefHeight="56.0" prefWidth="1280.0" spacing="0" style="-fx-background-color: #1c1436;                      -fx-border-color: rgba(123,44,255,0.25);                      -fx-border-width: 0 0 1 0;                      -fx-padding: 0 18 0 18;">

            <!-- ── LEFT: App name ── -->
            <HBox alignment="CENTER_LEFT" minWidth="280" prefWidth="280" spacing="10">
                <!-- App name -->
                <Label style="-fx-text-fill: #f0eaff;                               -fx-font-size: 18px;                               -fx-font-family: 'DM Sans';                               -fx-font-weight: bold;" text="ComOwl" />
                <Label fx:id="userIdLabel" style="-fx-text-fill: rgba(155,136,204,0.55);                               -fx-font-size: 12px;                               -fx-font-family: 'DM Sans';" text="" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />

            <!-- ── RIGHT: Friend requests + Notifications + Profile ── -->
            <HBox alignment="CENTER_RIGHT" spacing="6">

                <!-- Friend Requests icon -->
                <StackPane>
                    <Button fx:id="friendRequestsBtn" mnemonicParsing="false" onAction="#onFriendRequestsClick" prefHeight="38" prefWidth="38" style="-fx-background-color: linear-gradient(to bottom right, #9b30ff, #6d12e8); -fx-background-radius: 19; -fx-border-color: transparent; -fx-border-radius: 19; -fx-border-width: 1; -fx-text-fill: #c4b0ff; -fx-font-size: 16px;">
                        <cursor><Cursor fx:constant="HAND" /></cursor>
                    </Button>
                    <!-- Icon drawn over button -->
                    <Label mouseTransparent="true" style="-fx-font-size: 15px;" text="👥" />
                    <!-- Badge -->
                    <Label fx:id="friendRequestBadge" style="-fx-background-color: #ef4444;                                   -fx-text-fill: white;                                   -fx-font-size: 9px;                                   -fx-font-family: 'DM Sans';                                   -fx-font-weight: bold;                                   -fx-background-radius: 8;                                   -fx-padding: 1 4 1 4;                                   -fx-min-width: 16;                                   -fx-alignment: center;" text="0" translateX="6" translateY="-6" visible="false" StackPane.alignment="TOP_RIGHT" />
                </StackPane>

                <!-- Profile icon -->
                <StackPane>
                    <Button fx:id="profileMenuBtn" mnemonicParsing="false" onAction="#onProfileMenuClick" prefHeight="38" prefWidth="38" style="-fx-background-color: rgba(123,44,255,0.15);                                    -fx-background-radius: 19;                                    -fx-border-color: rgba(123,44,255,0.25);                                    -fx-border-radius: 19;                                    -fx-border-width: 1;                                    -fx-text-fill: #c4b0ff;                                    -fx-font-size: 16px;">
                        <cursor><Cursor fx:constant="HAND" /></cursor>
                    </Button>
                </StackPane>

            </HBox>
        </HBox>



        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  LEFT SIDEBAR  (x=0, y=56, 280×664)                       -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Pane fx:id="leftbase" layoutY="56.0" prefHeight="664.0" prefWidth="280.0" style="-fx-background-color: #16102b;                      -fx-border-color: rgba(123,44,255,0.18);                      -fx-border-width: 0 1 0 0;">
            <children>

                <!-- ── Search at top of conversation list ── -->
                <HBox alignment="CENTER" layoutY="8" prefHeight="44" prefWidth="280" style="-fx-padding: 0 12 8 12;">
                    <TextField fx:id="globalSearch" onKeyReleased="#onGlobalSearchTyped" prefHeight="36" prefWidth="256" promptText="🔍 Search people..." style="-fx-background-color: #231a3d; -fx-background-radius: 18; -fx-border-color: rgba(123,44,255,0.3); -fx-border-radius: 18; -fx-border-width: 1; -fx-text-fill: #f0eaff; -fx-prompt-text-fill: #6b5a8a; -fx-font-size: 12px; -fx-font-family: 'DM Sans'; -fx-padding: 0 14;" />
                </HBox>

                <!-- ── Tabs ── -->
                <HBox layoutY="58" prefHeight="38" prefWidth="280" spacing="0" style="-fx-background-color: #1c1436;                              -fx-padding: 4 12 4 12;">
                    <Button fx:id="usersTabBtn" mnemonicParsing="false" onAction="#onUsersTabClick" prefHeight="30" prefWidth="122" style="-fx-background-color: #7B2CFF;                                    -fx-background-radius: 15 0 0 15;                                    -fx-border-color: transparent;                                    -fx-text-fill: white;                                    -fx-font-size: 12px;                                    -fx-font-family: 'DM Sans';" text="💬  Chats">
                        <cursor><Cursor fx:constant="HAND" /></cursor>
                    </Button>
                    <Button fx:id="groupsTabBtn" mnemonicParsing="false" onAction="#onGroupsTabClick" prefHeight="30" prefWidth="122" style="-fx-background-color: #2a1f47;                                    -fx-background-radius: 0 15 15 0;                                    -fx-border-color: rgba(123,44,255,0.4);                                    -fx-border-width: 1 1 1 0;                                    -fx-border-radius: 0 15 15 0;                                    -fx-text-fill: #9b88cc;                                    -fx-font-size: 12px;                                    -fx-font-family: 'DM Sans';" text="👥  Groups">
                        <cursor><Cursor fx:constant="HAND" /></cursor>
                    </Button>
                </HBox>

                <!-- ── Contact list ── -->
                <ScrollPane fx:id="leftpane" fitToWidth="true" hbarPolicy="NEVER" layoutY="88" prefHeight="576" prefWidth="280" style="-fx-background-color: transparent;                                    -fx-background: transparent;                                    -fx-border-color: transparent;" vbarPolicy="AS_NEEDED">
                    <content>
                        <VBox fx:id="friendslist" prefWidth="280" style="-fx-background-color: transparent;" />
                    </content>
                </ScrollPane>

                <!-- Hidden fx:id kept for controller compatibility -->
                <HBox fx:id="userCard" managed="false" prefHeight="0" prefWidth="0" visible="false" />
                <ImageView fx:id="userImageSidebar" fitHeight="0" fitWidth="0" managed="false" visible="false">
                    <clip><Circle fx:id="userImageClipSidebar" radius="0" /></clip>
                </ImageView>

            </children>
        </Pane>


        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  CENTER CHAT AREA  (x=280, y=56, 720×664)                 -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Pane layoutX="280.0" layoutY="56.0" prefHeight="664.0" prefWidth="720.0" style="-fx-background-color: #0f0a1e;">
            <children>
                <VBox fx:id="chatbody" prefHeight="664.0" prefWidth="720.0">

                    <!-- ── Chat Header ── -->
                    <HBox fx:id="clientCard" alignment="CENTER_LEFT" prefHeight="62.0" prefWidth="720.0" spacing="14" style="-fx-background-color: #16102b;                                  -fx-border-color: rgba(123,44,255,0.18);                                  -fx-border-width: 0 0 1 0;                                  -fx-padding: 0 16 0 20;">

                        <StackPane prefHeight="44" prefWidth="44">
                            <Circle centerX="22" centerY="22" fill="#251a45" radius="22" />
                            <ImageView fx:id="clientImage" fitHeight="40" fitWidth="40">
                                <clip>
                                    <Circle fx:id="clientImageClip" centerX="20" centerY="20" radius="20" />
                                </clip>
                            </ImageView>
                            <Circle centerX="35" centerY="35" fill="#22c55e" radius="6" stroke="#16102b" strokeWidth="2" StackPane.alignment="BOTTOM_RIGHT" />
                        </StackPane>

                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label fx:id="clientIdLabel" maxWidth="Infinity" style="-fx-text-fill: #f0eaff;                                           -fx-font-size: 15px;                                           -fx-font-family: 'DM Sans';                                           -fx-font-weight: bold;" text="Select a conversation" />
                            <Label style="-fx-text-fill: #6b5a8a;                                           -fx-font-size: 11px;                                           -fx-font-family: 'DM Sans';" text="tap to view profile" />
                        </VBox>

                        <TextField fx:id="searchMessages" managed="false" prefWidth="180" promptText="Search in chat..." style="-fx-background-color: #231a3d;                                           -fx-background-radius: 16;                                           -fx-border-color: rgba(123,44,255,0.4);                                           -fx-border-radius: 16;                                           -fx-border-width: 1;                                           -fx-text-fill: #f0eaff;                                           -fx-prompt-text-fill: #6b5a8a;                                           -fx-font-size: 12px;                                           -fx-padding: 6 14 6 14;" visible="false" />

                        <HBox fx:id="headerButtonsBox" alignment="CENTER_RIGHT" spacing="6">
                            <Button fx:id="searchBtn" mnemonicParsing="false" onAction="#onSearchButtonClick" prefHeight="36" prefWidth="36" style="-fx-background-color: linear-gradient(to bottom right, #9b30ff, #6d12e8); -fx-background-radius: 18; -fx-border-color: transparent; -fx-border-radius: 18; -fx-border-width: 1; -fx-font-size: 14px;" text="🔍">
                                <cursor><Cursor fx:constant="HAND" /></cursor>
                            </Button>
                            <Button fx:id="audiocall" mnemonicParsing="false" onAction="#onAudioCallClick" prefHeight="36" prefWidth="36" style="-fx-background-color: linear-gradient(to bottom right, #9b30ff, #6d12e8); -fx-background-radius: 18; -fx-border-color: transparent; -fx-border-radius: 18; -fx-border-width: 1; -fx-font-size: 14px;" text="☎">
                                <cursor><Cursor fx:constant="HAND" /></cursor>
                            </Button>
                            <Button fx:id="videocall" mnemonicParsing="false" onAction="#onVideoCallClick" prefHeight="36" prefWidth="36" style="-fx-background-color: linear-gradient(to bottom right, #9b30ff, #6d12e8); -fx-background-radius: 18; -fx-border-color: transparent; -fx-border-radius: 18; -fx-border-width: 1; -fx-font-size: 14px;" text="📹">
                                <cursor><Cursor fx:constant="HAND" /></cursor>
                            </Button>
                            <Button fx:id="infobtn" mnemonicParsing="false" onAction="#onInfoButtonClick" prefHeight="36" prefWidth="36" style="-fx-background-color: linear-gradient(to bottom right, #9b30ff, #6d12e8); -fx-background-radius: 18; -fx-border-color: transparent; -fx-border-radius: 18; -fx-text-fill: #c4b0ff; -fx-border-width: 1; -fx-font-size: 14px; -fx-font-weight: bold;" text="⋯">
                                <cursor><Cursor fx:constant="HAND" /></cursor>
                            </Button>
                        </HBox>
                    </HBox>

                    <!-- ── Message Area ── -->
                    <Pane prefWidth="720.0" VBox.vgrow="ALWAYS">

                        <ImageView fx:id="chatBG" fitHeight="602.0" fitWidth="720.0" opacity="0.07" pickOnBounds="true" preserveRatio="false">
                            <image>
                                <Image url="@../Images/hogwarts_background.jpg" />
                            </image>
                        </ImageView>

                        <ScrollPane fx:id="chatScroll" fitToWidth="true" hbarPolicy="NEVER" prefHeight="602.0" prefWidth="720.0" style="-fx-background-color: transparent;                                            -fx-background: transparent;                                            -fx-border-color: transparent;" vbarPolicy="AS_NEEDED">
                            <content>
                                <VBox fx:id="msgbox" prefWidth="720.0" spacing="4">
                                    <padding>
                                        <Insets bottom="16" left="16" right="16" top="16" />
                                    </padding>
                                </VBox>
                            </content>
                        </ScrollPane>

                        <VBox fx:id="groupProfilePane" managed="false" prefHeight="602.0" prefWidth="720.0" spacing="0" styleClass="group-profile-pane" visible="false" />

                        <StackPane fx:id="chatStateOverlay" mouseTransparent="true" pickOnBounds="false" prefHeight="602.0" prefWidth="720.0">
                            <children>
                                <VBox fx:id="chatLoadingPane" alignment="CENTER" managed="false" maxHeight="Infinity" maxWidth="Infinity" spacing="14" style="-fx-background-color: rgba(15,10,30,0.85);" visible="false">
                                    <ProgressIndicator fx:id="chatLoadingIndicator" prefHeight="42" prefWidth="42" />
                                    <Label fx:id="chatLoadingLabel" style="-fx-text-fill: #9b88cc;                                                   -fx-font-size: 13px;                                                   -fx-font-family: 'DM Sans';" text="Loading messages..." />
                                </VBox>
                                <VBox fx:id="chatErrorPane" alignment="TOP_CENTER" managed="false" pickOnBounds="false" visible="false" StackPane.alignment="TOP_CENTER">
                                    <padding><Insets left="14" right="14" top="14" /></padding>
                                    <Label fx:id="chatErrorLabel" maxWidth="580" style="-fx-text-fill: #fca5a5;                                                   -fx-background-color: rgba(220,38,38,0.2);                                                   -fx-background-radius: 10;                                                   -fx-border-color: rgba(220,38,38,0.4);                                                   -fx-border-radius: 10;                                                   -fx-border-width: 1;                                                   -fx-padding: 10 16;                                                   -fx-font-size: 12px;                                                   -fx-font-family: 'DM Sans';" wrapText="true" />
                                </VBox>
                            </children>
                        </StackPane>

                        <StackPane fx:id="callOverlay" prefHeight="602.0" prefWidth="720.0" style="-fx-background-color: rgba(0,0,0,0.82);" visible="false" />
                    </Pane>

                    <!-- ── Input Bar ── -->
                    <HBox alignment="CENTER" prefHeight="62.0" prefWidth="720.0" spacing="10" style="-fx-background-color: #16102b;                                  -fx-border-color: rgba(123,44,255,0.18);                                  -fx-border-width: 1 0 0 0;                                  -fx-padding: 11 16 11 16;">
                        <Button fx:id="sendFile" mnemonicParsing="false" onAction="#onSendFileClick" prefHeight="38" prefWidth="38" style="-fx-background-color: linear-gradient(to bottom right, #9b30ff, #6d12e8); -fx-background-radius: 19; -fx-border-color: transparent; -fx-border-radius: 19; -fx-border-width: 1; -fx-font-size: 14px;" text="📎">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>

                        <StackPane HBox.hgrow="ALWAYS">
                            <TextField fx:id="msgField" prefHeight="40" promptText="Write a message..." style="-fx-background-color: #231a3d;                                           -fx-background-radius: 20;                                           -fx-border-color: rgba(123,44,255,0.35);                                           -fx-border-radius: 20;                                           -fx-border-width: 1;                                           -fx-text-fill: #f0eaff;                                           -fx-prompt-text-fill: #6b5a8a;                                           -fx-font-size: 14px;                                           -fx-font-family: 'DM Sans';                                           -fx-padding: 0 18 0 18;" />
                            
                            <HBox fx:id="recordingOverlay" alignment="CENTER_LEFT" managed="false" spacing="10" styleClass="recording-overlay" visible="false">
                                <children>
                                    <Circle fx:id="recordingDot" radius="5" styleClass="recording-dot" />
                                    <Label styleClass="recording-text" text="Recording..." />
                                    <Label fx:id="recordingTimeLabel" styleClass="recording-timer" text="0:00" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 11px;" text="Release to send" />
                                </children>
                            </HBox>
                        </StackPane>

                        <Button fx:id="voiceMsgBtn"
                                mnemonicParsing="false"
                                onMousePressed="#onVoiceMessageStart"
                                onMouseReleased="#onVoiceMessageStop"
                                prefHeight="38" prefWidth="38"
                                style="-fx-background-color: linear-gradient(to bottom right, #9b30ff, #6d12e8); -fx-background-radius: 19; -fx-border-color: transparent; -fx-border-radius: 19; -fx-border-width: 1; -fx-font-size: 14px;"
                                text="🎤">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>
                        <Button fx:id="sendEmoji" mnemonicParsing="false" onAction="#onEmojiButtonClick" prefHeight="38" prefWidth="38" style="-fx-background-color: rgba(123,44,255 linear-gradient(to bottom right, #9b30ff, #6d12e8),0.15); -fx-background-radius: 19; -fx-border-color: transparent; -fx-border-radius: 19; -fx-border-width: 1; -fx-font-size: 14px;" text="😊">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>
                        <Button fx:id="sendMsg" mnemonicParsing="false" onAction="#onSendMessageClick" prefHeight="40" prefWidth="40" style="-fx-background-color: linear-gradient(to bottom right, #9b30ff, #6d12e8);                                        -fx-background-radius: 20;                                        -fx-border-color: transparent;                                        -fx-text-fill: white;                                        -fx-font-size: 16px;                                        -fx-effect: dropshadow(gaussian,rgba(123,44,255,0.55),10,0,0,2);" text="➤">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>
                    </HBox>

                </VBox>
            </children>
        </Pane>


        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  RIGHT PANEL  (x=1000, y=56, 280×664)                     -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <StackPane layoutX="1000.0" layoutY="56.0" prefHeight="664.0" prefWidth="280.0">
            <children>

                <ImageView fitHeight="664.0" fitWidth="280.0" opacity="0.12" pickOnBounds="true" preserveRatio="false">
                    <image>
                        <Image url="@../Images/LoginForm/sidebar.gif" />
                    </image>
                </ImageView>

                <Pane prefHeight="664.0" prefWidth="280.0" style="-fx-background-color: rgba(22,16,43,0.97);                              -fx-border-color: rgba(123,44,255,0.18);                              -fx-border-width: 0 0 0 1;" />

                <!-- ── AI Panel ── -->
                <Pane fx:id="geminiPane" prefHeight="664.0" prefWidth="280.0" style="-fx-background-color: rgba(15,10,30,0.97);" visible="false">
                    <children>
                        <HBox alignment="CENTER_LEFT" layoutX="0" layoutY="0" prefHeight="56" prefWidth="280" spacing="10" style="-fx-background-color: #1c1436;                                      -fx-border-color: rgba(123,44,255,0.2);                                      -fx-border-width: 0 0 1 0;                                      -fx-padding: 0 14 0 16;">
                            <Label style="-fx-text-fill: #9b30ff; -fx-font-size: 18px;" text="✦" />
                            <Label style="-fx-text-fill: #f0eaff;                                           -fx-font-size: 15px;                                           -fx-font-family: 'DM Sans';                                           -fx-font-weight: bold;" text="AI Assistant" HBox.hgrow="ALWAYS" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button mnemonicParsing="false" onAction="#onGeminiClearClick" prefHeight="28" prefWidth="60" style="-fx-background-color: rgba(123,44,255,0.25);                                            -fx-background-radius: 14;                                            -fx-border-color: rgba(123,44,255,0.4);                                            -fx-border-radius: 14;                                            -fx-border-width: 1;                                            -fx-text-fill: #c4b0ff;                                            -fx-font-size: 11px;                                            -fx-font-family: 'DM Sans';" text="Clear">
                                <cursor><Cursor fx:constant="HAND" /></cursor>
                            </Button>
                        </HBox>

                        <ScrollPane fx:id="geminiscrollpane" fitToWidth="true" hbarPolicy="NEVER" layoutY="56" prefHeight="552" prefWidth="280" style="-fx-background-color: transparent;                                            -fx-background: transparent;                                            -fx-border-color: transparent;" vbarPolicy="AS_NEEDED">
                            <content>
                                <VBox fx:id="geminibox" prefWidth="280" spacing="8">
                                    <padding><Insets bottom="12" left="10" right="10" top="12" /></padding>
                                </VBox>
                            </content>
                        </ScrollPane>

                        <HBox alignment="CENTER" layoutX="10" layoutY="614" prefHeight="40" prefWidth="260" spacing="8">
                            <TextField fx:id="geminimsg" prefHeight="38" promptText="Ask AI anything..." style="-fx-background-color: #231a3d;                                               -fx-background-radius: 19;                                               -fx-border-color: rgba(123,44,255,0.35);                                               -fx-border-radius: 19;                                               -fx-border-width: 1;                                               -fx-text-fill: #f0eaff;                                               -fx-prompt-text-fill: #6b5a8a;                                               -fx-font-size: 12px;                                               -fx-padding: 0 12 0 12;" HBox.hgrow="ALWAYS" />
                            <Button fx:id="geminisend" mnemonicParsing="false" onAction="#onGeminiSendClick" prefHeight="38" prefWidth="38" style="-fx-background-color: linear-gradient(to bottom right, #9b30ff, #6d12e8);                                            -fx-background-radius: 19;                                            -fx-border-color: transparent;                                            -fx-text-fill: white;                                            -fx-font-size: 14px;" text="➤">
                                <cursor><Cursor fx:constant="HAND" /></cursor>
                            </Button>
                        </HBox>
                    </children>
                </Pane>

                <!-- ── Info / Profile Panel ── -->
                <Pane fx:id="infoPane" prefHeight="664.0" prefWidth="280.0" style="-fx-background-color: transparent;">
                    <children>

                        <Button fx:id="createGroupBtn" layoutX="16" layoutY="14" mnemonicParsing="false" onAction="#createGroup" prefHeight="36" prefWidth="248" style="-fx-background-color: rgba(123,44,255,0.2);                                        -fx-background-radius: 18;                                        -fx-border-color: rgba(123,44,255,0.5);                                        -fx-border-radius: 18;                                        -fx-border-width: 1;                                        -fx-text-fill: #c4b0ff;                                        -fx-font-size: 13px;                                        -fx-font-family: 'DM Sans';" text="＋  New Group">
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>

                        <Rectangle fill="rgba(123,44,255,0.15)" height="1" layoutX="16" layoutY="62" width="248" />

                        <StackPane layoutX="100" layoutY="76" prefHeight="80" prefWidth="80">
                            <Circle centerX="40" centerY="40" fill="#251a45" radius="40" stroke="rgba(123,44,255,0.4)" strokeWidth="2" />
                            <ImageView fx:id="userImage1" fitHeight="76" fitWidth="76">
                                <clip>
                                    <Circle fx:id="userImageClip1" centerX="38" centerY="38" radius="38" />
                                </clip>
                            </ImageView>
                        </StackPane>

                        <VBox layoutX="16" layoutY="170" spacing="2">
                            <Label style="-fx-text-fill: rgba(155,136,204,0.6);                                           -fx-font-size: 10px;                                           -fx-font-family: 'DM Sans';" text="USERNAME" />
                            <Label fx:id="USERNAME" prefWidth="248" style="-fx-text-fill: #f0eaff;                                           -fx-font-size: 15px;                                           -fx-font-family: 'DM Sans';                                           -fx-font-weight: bold;" />
                        </VBox>

                        <Rectangle fill="rgba(123,44,255,0.15)" height="1" layoutX="16" layoutY="218" width="248" />

                        <VBox layoutX="16" layoutY="228" spacing="4">
                            <Label style="-fx-text-fill: rgba(155,136,204,0.6);                                           -fx-font-size: 10px;                                           -fx-font-family: 'DM Sans';" text="STATUS" />
                            <HBox alignment="CENTER_LEFT" spacing="6">
                                <Circle fill="#22c55e" radius="5" />
                                <Label style="-fx-text-fill: #22c55e;                                               -fx-font-size: 13px;                                               -fx-font-family: 'DM Sans';" text="Active now" />
                            </HBox>
                        </VBox>

                        <Rectangle fill="rgba(123,44,255,0.15)" height="1" layoutX="16" layoutY="274" width="248" />

