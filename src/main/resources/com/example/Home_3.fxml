<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" stylesheets="@style-home.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.HomeController">

   <BorderPane AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
               AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

      <!-- Top Bar -->
      <top>
         <HBox alignment="CENTER_LEFT" styleClass="top-bar" spacing="15.0">
            <padding><Insets left="20.0" right="20.0" /></padding>

            <!-- Logo -->
            <Label styleClass="logo" text="PingOwl" />

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS" />

            <!-- Friend Request Icon -->
            <StackPane onMouseClicked="#showFriendRequests" styleClass="icon-button">
               <Label styleClass="icon" text="👥" />
               <Label fx:id="requestBadge" styleClass="badge"
                      visible="false" StackPane.alignment="TOP_RIGHT" />
            </StackPane>

            <!-- Notification Icon -->
            <StackPane onMouseClicked="#showNotifications" styleClass="icon-button">
               <Label styleClass="icon" text="🔔" />
               <Label fx:id="notificationBadge" styleClass="badge"
                      visible="false" StackPane.alignment="TOP_RIGHT" />
            </StackPane>

            <!-- Profile Picture -->
            <StackPane onMouseClicked="#showProfile" styleClass="profile-button">
               <ImageView fx:id="profileImageView" fitHeight="40.0" fitWidth="40.0"
                          preserveRatio="false" />
               <Circle radius="20" stroke="white" strokeWidth="2" fill="transparent" />
            </StackPane>

            <!-- Name -->
            <Label fx:id="userNameLabel" styleClass="user-name" />
         </HBox>
      </top>

      <!-- Left Sidebar -->
      <left>
         <VBox styleClass="sidebar-left" spacing="0.0">
            <!-- User Profile Area -->
            <HBox styleClass="user-profile-area" alignment="CENTER_LEFT" spacing="12.0">
               <padding><Insets left="15.0" right="15.0" top="15.0" bottom="15.0" /></padding>

               <StackPane>
                  <ImageView fx:id="sidebarProfileImage" fitHeight="48.0" fitWidth="48.0"
                             preserveRatio="false" />
                  <Circle radius="24" stroke="white" strokeWidth="2" fill="transparent" />
               </StackPane>

               <VBox spacing="2.0">
                  <Label fx:id="sidebarUserName" styleClass="user-name-large" />
                  <Label styleClass="user-email" fx:id="sidebarUserEmail" />
               </VBox>
            </HBox>

            <!-- Search Bar -->
            <VBox spacing="0.0">
               <TextField fx:id="searchField" onKeyReleased="#onSearchTyped"
                          styleClass="search-field" promptText="🔍 Search friends..." />

               <!-- Search Results Dropdown -->
               <VBox fx:id="searchResultPanel" styleClass="search-results-panel"
                     managed="false" visible="false">
                  <ListView fx:id="searchResultListView" styleClass="search-results-list" />
               </VBox>
            </VBox>

            <!-- Friends List Header -->
            <HBox styleClass="list-header" alignment="CENTER_LEFT">
               <padding><Insets left="15.0" right="15.0" top="12.0" bottom="8.0" /></padding>
               <Label styleClass="list-header-label" text="CHATS" />
               <Region HBox.hgrow="ALWAYS" />
               <Label onMouseClicked="#refreshFriendList" styleClass="refresh-icon" text="↻" />
            </HBox>

            <!-- Friends/Chats List -->
            <ListView fx:id="friendListView" styleClass="friends-list" VBox.vgrow="ALWAYS" />
         </VBox>
      </left>

      <!-- Center Chat Area -->
      <center>
         <AnchorPane fx:id="chatContainer" styleClass="chat-container">
            <!-- No Chat Selected Placeholder -->
            <VBox fx:id="noChatPlaceholder" alignment="CENTER" spacing="15.0"
                  AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                  AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
                  styleClass="no-chat-placeholder">
               <Label styleClass="placeholder-icon" text="💬" />
               <Label styleClass="placeholder-text" text="Select a friend to start chatting" />
            </VBox>

            <!-- Chat Panel (initially hidden) -->
            <fx:include fx:id="chatView" source="ChatView.fxml"
                        AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                        AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" />
         </AnchorPane>
      </center>

   </BorderPane>

</AnchorPane>
