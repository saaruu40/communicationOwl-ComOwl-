<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.ChangeProfilePictureController"
            prefWidth="320.0"
            style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 15, 0, 0, 4);">

    <VBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
          spacing="15.0">

        <!-- Back -->
        <HBox alignment="CENTER_LEFT">
            <padding><Insets top="8" left="10" /></padding>
            <Label text="←" onMouseClicked="#goBack"
                   style="-fx-text-fill: #555; -fx-cursor: hand; -fx-font-size: 16px;" />
        </HBox>

        <!-- Profile Picture Preview -->
        <HBox alignment="CENTER">
            <ImageView fx:id="profileImageView"
                       fitHeight="180.0" fitWidth="180.0"
                       preserveRatio="false"
                       style="-fx-cursor: hand;"
                       onMouseClicked="#chooseImage" />
        </HBox>

        <!-- Buttons -->
        <HBox alignment="CENTER" spacing="15.0">
            <padding><Insets bottom="20" /></padding>
            <Button text="Upload" onMouseClicked="#chooseImage"
                    prefWidth="110.0" prefHeight="38.0"
                    style="-fx-background-color: #2a0168; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand; -fx-background-radius: 8;" />
            <Button text="Submit" onMouseClicked="#submitPicture"
                    prefWidth="110.0" prefHeight="38.0"
                    style="-fx-background-color: #2a0168; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand; -fx-background-radius: 8;" />
        </HBox>

    </VBox>
</AnchorPane>