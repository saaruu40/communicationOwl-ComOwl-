<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="500.0" prefWidth="400.0"
            style="-fx-background-color: #1a0a3a;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.ImageCropperController">

    <VBox spacing="10.0" AnchorPane.topAnchor="10.0" AnchorPane.bottomAnchor="10.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <padding>
            <Insets top="10.0" bottom="10.0" left="0.0" right="0.0" />
        </padding>

        <!-- Canvas Stack -->
        <StackPane fx:id="canvasPane" prefHeight="400.0" prefWidth="400.0">
            <Canvas fx:id="imageCanvas" width="400.0" height="400.0" />
            <Canvas fx:id="overlayCanvas" width="400.0" height="400.0" />
        </StackPane>

        <!-- Buttons -->
        <HBox spacing="10.0" alignment="CENTER">
            <Button fx:id="cancelButton" onMouseClicked="#cancelCrop"
                    prefWidth="120.0" prefHeight="40.0"
                    style="-fx-background-color: #3a1a5a; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand; -fx-border-color: #7B2CFF; -fx-border-radius: 4; -fx-background-radius: 4;"
                    text="Cancel" />
            <Button fx:id="cropButton" onMouseClicked="#cropImage"
                    prefWidth="120.0" prefHeight="40.0"
                    style="-fx-background-color: linear-gradient(to bottom, #7B2CFF, #5D16CC); -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand; -fx-border-radius: 4; -fx-background-radius: 4;"
                    text="Crop &amp; Save" />
        </HBox>

    </VBox>
</AnchorPane>